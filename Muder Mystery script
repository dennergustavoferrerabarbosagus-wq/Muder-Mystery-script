    if gethui then 
        return gethui() 
    end
    local sucesso, coreGui = pcall(function() return game:GetService("CoreGui") end)
    if sucesso and coreGui then 
        return coreGui 
    end
    return game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
end

