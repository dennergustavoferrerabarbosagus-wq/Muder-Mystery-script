    local function pegarPapel(jogador)
        local papel = "INOCENTE"
        local function checarItens(pasta)
            if not pasta then return end
            for _, item in pairs(pasta:GetChildren()) do
                if item:IsA("Tool") then
                    local nome = string.lower(item.Name)
                    if string.find(nome,"knife") or string.find(nome,"faca") then
                        papel = "ASSASSINO"
                    elseif string.find(nome,"gun") or string.find(nome,"revolver") then
                        if papel ~= "ASSASSINO" then papel = "XERIFE" end
                    end
                end
            end
        end
        checarItens(jogador.Backpack)
        if jogador.Character then checarItens(jogador.Character) end
        return papel
    end

    local function limparESP()
        for _, jogador in pairs(Players:GetPlayers()) do
            if jogador.Character then
                local h = jogador.Character:FindFirstChild("ESPHighlight")
                if h then h:Destroy() end
            end
        end
    end

    local function atualizarESP()
        for _, jogador in pairs(Players:GetPlayers()) do
            if jogador ~= LocalPlayer and jogador.Character and jogador.Character:FindFirstChild("HumanoidRootPart") then
                local papel = pegarPapel(jogador)
                local cor = Color3.fromRGB(0,255,0)

                if papel == "ASSASSINO" then cor = Color3.fromRGB(255,0,0)
                elseif papel == "XERIFE" then cor = Color3.fromRGB(0,0,255) end

                local highlight = jogador.Character:FindFirstChild("ESPHighlight")
                if not highlight then
                    highlight = Instance.new("Highlight")
                    highlight.Name = "ESPHighlight"
                    highlight.Parent = jogador.Character
                    highlight.FillTransparency = 0.5
                    highlight.OutlineTransparency = 0
                end
                highlight.FillColor = cor
                highlight.OutlineColor = cor
            end
        end
    end

    local function pegarAssassino()
        for _, jogador in pairs(Players:GetPlayers()) do
            if jogador ~= LocalPlayer and jogador.Character and jogador.Character:FindFirstChild("Head") and jogador.Character:FindFirstChild("HumanoidRootPart") then
                if pegarPapel(jogador) == "ASSASSINO" then return jogador end
            end
        end
        return nil
    end

    RunService.RenderStepped:Connect(function()
        if not AIMBOT_ATIVO then return end
        local assassino = pegarAssassino()
        if assassino then
            local head = assassino.Character.Head
            local hrp = assassino.Character.HumanoidRootPart
            local velocidade = hrp.AssemblyLinearVelocity
            local posicao = head.Position + (velocidade * PREDICAO)
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, posicao)
        end
    end)

    task.spawn(function()
        while task.wait(2) do
            if COIN_FARM then
                pcall(function()
                    local character = LocalPlayer.Character
                    if not character then return end
                    local hrp = character:FindFirstChild("HumanoidRootPart")
                    if not hrp then return end

                    for _, obj in pairs(workspace:GetDescendants()) do
                        local nome = string.lower(obj.Name)
                        if nome == "coin" or nome == "coins" or string.find(nome,"coin") then
                            if obj:IsA("BasePart") then
                                hrp.CFrame = obj.CFrame + Vector3.new(0,2,0)
                                break
                            end
                        end
                    end
                end)
            end
        end
    end)

    local function teleportarPara(tipo)
        for _, jogador in pairs(Players:GetPlayers()) do
            if jogador ~= LocalPlayer and jogador.Character and jogador.Character:FindFirstChild("HumanoidRootPart") then
                if pegarPapel(jogador) == tipo then
                    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then hrp.CFrame = jogador.Character.HumanoidRootPart.CFrame * CFrame.new(2,0,2) end
                    break
                end
            end
        end
    end

    local function teleportarInocente()
        local inocentes = {}
        for _, jogador in pairs(Players:GetPlayers()) do
            if jogador ~= LocalPlayer and jogador.Character and jogador.Character:FindFirstChild("HumanoidRootPart") then
                if pegarPapel(jogador) == "INOCENTE" then table.insert(inocentes,jogador) end
            end
        end
        if #inocentes > 0 then
            local escolhido = inocentes[math.random(1,#inocentes)]
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CFrame = escolhido.Character.HumanoidRootPart.CFrame * CFrame.new(2,0,2) end
        end
    end

    local function pegarGunDrop()
        local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local oldPos = hrp.CFrame
        local gunDrop = workspace:FindFirstChild("GunDrop", true)
        if gunDrop then
            hrp.CFrame = gunDrop.CFrame + Vector3.new(0,2,0)
            task.wait(0.5)
            hrp.CFrame = oldPos
        end
    end

