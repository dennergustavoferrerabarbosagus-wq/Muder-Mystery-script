                    LocalPlayer.Character

                    if not character then return end

                    local hrp =
                    character:FindFirstChild("HumanoidRootPart")

                    if not hrp then return end

                    for _, obj in pairs(workspace:GetDescendants()) do

                        local nome =
                        string.lower(obj.Name)

                        if nome == "coin"
                        or nome == "coins"
                        or string.find(nome,"coin") then

                            if obj:IsA("BasePart") then

                                hrp.CFrame =
                                obj.CFrame + Vector3.new(0,2,0)

                                break
                            end
                        end
                    end
                end)
            end
        end
    end)

    ---------------------------------------------------------
    -- TELEPORTES
    ---------------------------------------------------------
    local function teleportarPara(tipo)

        for _, jogador in pairs(Players:GetPlayers()) do

            if jogador ~= LocalPlayer
            and jogador.Character
            and jogador.Character:FindFirstChild("HumanoidRootPart") then

                if pegarPapel(jogador) == tipo then

                    local hrp =
                    LocalPlayer.Character and
                    LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

                    if hrp then

                        hrp.CFrame =
                        jogador.Character.HumanoidRootPart.CFrame
                        * CFrame.new(2,0,2)
                    end

                    break
                end
            end
        end
    end

    local function teleportarInocente()

        local inocentes = {}

        for _, jogador in pairs(Players:GetPlayers()) do

            if jogador ~= LocalPlayer
            and jogador.Character
            and jogador.Character:FindFirstChild("HumanoidRootPart") then

                if pegarPapel(jogador) == "INOCENTE" then
                    table.insert(inocentes,jogador)
                end
            end
        end

        if #inocentes > 0 then

            local escolhido =
            inocentes[math.random(1,#inocentes)]

            local hrp =
            LocalPlayer.Character and
            LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

            if hrp then

                hrp.CFrame =
                escolhido.Character.HumanoidRootPart.CFrame
                * CFrame.new(2,0,2)
            end
        end
    end

    local function pegarGunDrop()

        local character = LocalPlayer.Character
        if not character then return end

        local hrp =
        character:FindFirstChild("HumanoidRootPart")

        if not hrp then return end

        local oldPos = hrp.CFrame

        local gunDrop =
        workspace:FindFirstChild("GunDrop", true)

        if gunDrop then

            hrp.CFrame =
            gunDrop.CFrame + Vector3.new(0,2,0)

            task.wait(0.5)

            hrp.CFrame = oldPos
        end
    end

