    ---------------------------------------------------------
    -- PEGAR PAPEL
    ---------------------------------------------------------
    local function pegarPapel(jogador)

        local papel = "INOCENTE"

        local function checarItens(pasta)

            if not pasta then return end

            for _, item in pairs(pasta:GetChildren()) do

                if item:IsA("Tool") then

                    local nome =
                    string.lower(item.Name)

                    if string.find(nome,"knife")
                    or string.find(nome,"faca") then

                        papel = "ASSASSINO"

                    elseif string.find(nome,"gun")
                    or string.find(nome,"revolver") then

                        if papel ~= "ASSASSINO" then
                            papel = "XERIFE"
                        end
                    end
                end
            end
        end

        checarItens(jogador.Backpack)

        if jogador.Character then
            checarItens(jogador.Character)
        end

        return papel
    end

    ---------------------------------------------------------
    -- ESP
    ---------------------------------------------------------
    local function limparESP()

        for _, jogador in pairs(Players:GetPlayers()) do

            if jogador.Character then

                local h =
                jogador.Character:FindFirstChild("ESPHighlight")

                if h then
                    h:Destroy()
                end
            end
        end
    end

    local function atualizarESP()

        for _, jogador in pairs(Players:GetPlayers()) do

            if jogador ~= LocalPlayer
            and jogador.Character
            and jogador.Character:FindFirstChild("HumanoidRootPart") then

                local papel = pegarPapel(jogador)

                local cor = Color3.fromRGB(0,255,0)

                if papel == "ASSASSINO" then
                    cor = Color3.fromRGB(255,0,0)
                elseif papel == "XERIFE" then
                    cor = Color3.fromRGB(0,0,255)
                end

                local highlight =
                jogador.Character:FindFirstChild("ESPHighlight")

                if not highlight then

                    highlight = Instance.new("Highlight")
                    highlight.Name = "ESPHighlight"
                    highlight.Parent = jogador.Character
                    highlight.FillTransparency = 0.5
                    highlight.OutlineTransparency = 0
                end

                highlight.FillColor = cor
                highlight.OutlineColor = cor
            end
        end
    end

    ---------------------------------------------------------
    -- AIMBOT
    ---------------------------------------------------------
    local function pegarAssassino()

        for _, jogador in pairs(Players:GetPlayers()) do

            if jogador ~= LocalPlayer
            and jogador.Character
            and jogador.Character:FindFirstChild("Head")
            and jogador.Character:FindFirstChild("HumanoidRootPart") then

                if pegarPapel(jogador) == "ASSASSINO" then
                    return jogador
                end
            end
        end

        return nil
    end

    RunService.RenderStepped:Connect(function()

        if not AIMBOT_ATIVO then
            return
        end

        local assassino = pegarAssassino()

        if assassino then

            local head =
            assassino.Character.Head

            local hrp =
            assassino.Character.HumanoidRootPart

            local velocidade =
            hrp.AssemblyLinearVelocity

            local posicao =
            head.Position + (velocidade * PREDICAO)

            Camera.CFrame =
            CFrame.new(
                Camera.CFrame.Position,
                posicao
            )
        end
    end)

